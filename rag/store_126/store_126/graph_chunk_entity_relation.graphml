</node>
<node id="Code Inspection">
  <data key="d0">Code Inspection</data>
  <data key="d1">method</data>
  <data key="d2">Code inspection (Fagan inspection) is a highly structured method focused on identifying faults and violations in the code.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830373</data>
  <data key="d6"></data>
</node>
<node id="Author">
  <data key="d0">Author</data>
  <data key="d1">person</data>
  <data key="d2">The author is the person who wrote the code and presents their perspective during code inspection.&lt;SEP&gt;The author is responsible for fixing defects found during the inspection meeting.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044&lt;SEP&gt;chunk-c584edf6e5f2b8db471597d14e5d0bd0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830595</data>
  <data key="d6"></data>
</node>
<node id="Inspectors">
  <data key="d0">Inspectors</data>
  <data key="d1">person</data>
  <data key="d2">Inspectors review the code and provide comments during the code inspection process.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830375</data>
  <data key="d6"></data>
</node>
<node id="Scribe">
  <data key="d0">Scribe</data>
  <data key="d1">person</data>
  <data key="d2">The scribe takes detailed notes during the inspection meeting and distributes them to the team.&lt;SEP&gt;A scribe formally documents defects found in an inspection meeting.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044&lt;SEP&gt;chunk-c584edf6e5f2b8db471597d14e5d0bd0</data>
