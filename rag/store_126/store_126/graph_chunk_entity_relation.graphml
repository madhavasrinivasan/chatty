  <data key="d5">1770830830</data>
  <data key="d6"></data>
</node>
<node id="Test Suite">
  <data key="d0">Test Suite</data>
  <data key="d1">method</data>
  <data key="d2">A collection of test cases that should not be hard coded.</data>
  <data key="d3">chunk-b6de8307f33f851b1e62ada0a1e5b961</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830830</data>
  <data key="d6"></data>
</node>
<node id="Test Framework">
  <data key="d0">Test Framework</data>
  <data key="d1">method</data>
  <data key="d2">The test framework takes care of the execution process and ensures code reusability.&lt;SEP&gt;A test framework is a module that combines what to execute and how they have to be executed, considered the core of automation design.</data>
  <data key="d3">chunk-b6de8307f33f851b1e62ada0a1e5b961&lt;SEP&gt;chunk-f9a1e0b0e37c96741aefa49dc8030cdc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831789</data>
  <data key="d6"></data>
</node>
<node id="T2">
  <data key="d0">T2</data>
  <data key="d1">data</data>
  <data key="d2">T2 represents a test case in the Decision Table.</data>
  <data key="d3">chunk-ff3bcd5d811cf1d3238112df22f24549</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830831</data>
  <data key="d6"></data>
</node>
<node id="T3">
  <data key="d0">T3</data>
  <data key="d1">data</data>
  <data key="d2">T3 represents a test case in the Decision Table.</data>
  <data key="d3">chunk-ff3bcd5d811cf1d3238112df22f24549</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830831</data>
  <data key="d6"></data>
</node>
<node id="Error Guessing">
  <data key="d0">Error Guessing</data>
  <data key="d1">method</data>
  <data key="d2">Error Guessing is a test case design approach based on the tester's or developer's experience and intuition to identify potential defects in the code.&lt;SEP&gt;Error Guessing is a black box testing method where testers use their experience to guess potential errors.&lt;SEP&gt;Error guessing is an ad hoc approach to test design.</data>
  <data key="d3">chunk-ff3bcd5d811cf1d3238112df22f24549&lt;SEP&gt;chunk-4236e7b8427ccbaff16d4b0ef1506341&lt;SEP&gt;chunk-ac6e3a12af74abf6be605f347823c7a8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831106</data>
  <data key="d6"></data>
</node>
<node id="Test Data">
  <data key="d0">Test Data</data>
  <data key="d1">data</data>
  <data key="d2">Test data is automatically archived.&lt;SEP&gt;Test data is the information used to evaluate software during testing.&lt;SEP&gt;Test data refers to the set of inputs, conditions, and expected results used to test a program.</data>
  <data key="d3">chunk-b6de8307f33f851b1e62ada0a1e5b961&lt;SEP&gt;chunk-da9b3662c0429d5ef91b33c626c7ba44&lt;SEP&gt;chunk-dbbf2f5da383a1fc924d351d3652477f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831384</data>
  <data key="d6"></data>
</node>
<node id="Managers">
  <data key="d0">Managers</data>
  <data key="d1">person</data>
  <data key="d2">Managers are responsible for making critical decisions regarding the software testing process.&lt;SEP&gt;Managers are part of the team to evaluate the effectiveness of the testing efforts using the Test Summary Report.</data>
  <data key="d3">chunk-0ad834ab92932d983e93d86d224421e9&lt;SEP&gt;chunk-2b3c34fc8c737800e72c4ba3dd2c8eff</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831394</data>
  <data key="d6"></data>
</node>
<node id="Stop-Test Criteria">
  <data key="d0">Stop-Test Criteria</data>
  <data key="d1">concept</data>
  <data key="d2">Stop-test criteria are quantifiable conditions that, when met, indicate that software testing should be halted.</data>
  <data key="d3">chunk-0ad834ab92932d983e93d86d224421e9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830849</data>
  <data key="d6"></data>
</node>
<node id="Fault Seeding">
  <data key="d0">Fault Seeding</data>
  <data key="d1">method</data>
