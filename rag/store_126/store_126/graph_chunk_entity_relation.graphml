  <data key="d0">Conditional Accept</data>
  <data key="d1">concept</data>
  <data key="d2">Conditional Accept refers to a status where the reviewed item needs rework that will be checked by the moderator.</data>
  <data key="d3">chunk-1a701e33391919caf4151b2a9d6fa069</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830350</data>
