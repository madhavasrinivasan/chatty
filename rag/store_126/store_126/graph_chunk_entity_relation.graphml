  <data key="d0">Random Regression</data>
  <data key="d1">method</data>
  <data key="d2">Random Regression is a regression testing methodology where test cases are selected randomly for execution.</data>
  <data key="d3">chunk-56db660e3609aef43610e61aa17e8a81</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830372</data>
  <data key="d6"></data>
</node>
<node id="Context Based Dynamic Regression">
  <data key="d0">Context Based Dynamic Regression</data>
  <data key="d1">method</data>
  <data key="d2">Context Based Dynamic Regression is a regression testing methodology where test cases are selected based on the context and dynamically.</data>
  <data key="d3">chunk-56db660e3609aef43610e61aa17e8a81</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830372</data>
