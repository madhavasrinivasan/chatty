  <data key="d4">unknown_source</data>
  <data key="d5">1770830376</data>
  <data key="d6"></data>
</node>
<node id="Defect Logging Meeting">
  <data key="d0">Defect Logging Meeting</data>
  <data key="d1">event</data>
  <data key="d2">The defect logging meeting, where the inspection team assembles to discuss and classify defects found in the code.</data>
