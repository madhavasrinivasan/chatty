  <data key="d1">artifact</data>
  <data key="d2">The software item refers to the artifact under review.</data>
  <data key="d3">chunk-1a701e33391919caf4151b2a9d6fa069</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830347</data>
  <data key="d6"></data>
</node>
<node id="Moderator">
  <data key="d0">Moderator</data>
  <data key="d1">person</data>
  <data key="d2">The moderator reviews rework in the case of conditional accepts.&lt;SEP&gt;The moderator formally runs the inspection process, including scheduling the inspection meeting and guiding the team.&lt;SEP&gt;The individual who ensures the inspection process is completed after all problems have been resolved.</data>
  <data key="d3">chunk-1a701e33391919caf4151b2a9d6fa069&lt;SEP&gt;chunk-30509fdeb65cdfc4b7aaea9954573044&lt;SEP&gt;chunk-b7ff6ae81d2cbdd2fa63a7c1554d2eaf</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830613</data>
  <data key="d6"></data>
</node>
