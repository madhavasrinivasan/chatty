  <data key="d1">method</data>
  <data key="d2">Conditions Checking is a programming process to evaluate if a certain condition is true or false.</data>
  <data key="d3">chunk-52bc4ae0ed75d4c9e063e984a954b88b</data>
  <data key="d4">unknown_source</data>
