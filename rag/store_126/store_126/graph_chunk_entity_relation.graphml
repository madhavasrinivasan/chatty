</node>
<node id="Novice Tester">
  <data key="d0">Novice Tester</data>
  <data key="d1">concept</data>
  <data key="d2">A Novice Tester tests a module or component by employing all set of inputs and checks all the software structures.</data>
  <data key="d3">chunk-c7cd0ee78ddf28561be524a34f8204f8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830406</data>
