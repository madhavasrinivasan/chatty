  <data key="d0">Defect Fix Rate</data>
  <data key="d1">method</data>
  <data key="d2">Defect Fix Rate is a progress metric that measures the rate at which defects are resolved.&lt;SEP&gt;The rate at which defects are resolved as soon as they are identified.</data>
  <data key="d3">chunk-30553e0ee44e2324f5640d522949d67d&lt;SEP&gt;chunk-6293aec7ed87430ba4236ef6fa4fc8a2</data>
