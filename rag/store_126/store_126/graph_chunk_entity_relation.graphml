  <data key="d1">artifact</data>
  <data key="d2">The live system contains the actual data and configurations that are mirrored for online deployment testing.</data>
  <data key="d3">chunk-9d01d5a91698d48273a7f4da4a262d5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831193</data>
