</node>
<node id="Desk Checking">
  <data key="d0">Desk Checking</data>
  <data key="d1">method</data>
  <data key="d2">Desk checking is a manual method used by the code's author to verify its correctness before compiling and executing it.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830372</data>
  <data key="d6"></data>
</node>
<node id="Code Walkthrough">
  <data key="d0">Code Walkthrough</data>
  <data key="d1">method</data>
  <data key="d2">Code walkthrough is a method where a group of people reviews the program code and asks questions.&lt;SEP&gt;A process where every reviewer leads the group in inspecting a specific line or a section of the code.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044&lt;SEP&gt;chunk-b7ff6ae81d2cbdd2fa63a7c1554d2eaf</data>
  <data key="d4">unknown_source</data>
