  <data key="d6"></data>
</node>
<node id="Minor Defects">
  <data key="d0">Minor Defects</data>
  <data key="d1">concept</data>
  <data key="d2">Minor defects are those that are not expected to substantially affect a program.&lt;SEP&gt;Minor defects are defects that have a small impact on the functionality of the software.</data>
  <data key="d3">chunk-30509fdeb65cdfc4b7aaea9954573044&lt;SEP&gt;chunk-be51d63afa736d2292bcd95d0d343101</data>
