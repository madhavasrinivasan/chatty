  <data key="d1">concept</data>
  <data key="d2">Security refers to the degree to which software can detect and prevent information leak, information loss, illegal use, and system resource destruction.</data>
  <data key="d3">chunk-50ee503f2fae49523a55b9fcdc5df8d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831011</data>
