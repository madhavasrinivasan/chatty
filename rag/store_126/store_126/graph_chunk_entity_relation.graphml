  <data key="d5">1770830611</data>
  <data key="d6"></data>
</node>
<node id="Maintainability">
  <data key="d0">Maintainability</data>
  <data key="d1">concept</data>
  <data key="d2">Maintainability is a quality attribute partitioned into testability, correctability, and expandability.&lt;SEP&gt;Maintainability is the effort needed to make changes in software.</data>
  <data key="d3">chunk-c2d7d142472e7acf420224383c99b13b&lt;SEP&gt;chunk-7d1d7014ef279c74a7acb5889dca6440&lt;SEP&gt;chunk-ed0e4731c3296bc5ba3ae5edf4cd9631</data>
