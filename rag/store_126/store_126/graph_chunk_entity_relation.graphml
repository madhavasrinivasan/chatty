<node id="Hairpin">
  <data key="d0">Hairpin</data>
  <data key="d1">artifact</data>
  <data key="d2">Hairpin is an input used in test cases which should not cause any change or damage.&lt;SEP&gt;Hairpin is mentioned as an object used in test conditions for requirements BR-04 and BR-05.</data>
  <data key="d3">chunk-1d2b4e5470a5fae4ac0a621246515793&lt;SEP&gt;chunk-b1985b2f00f63e1c64f0933bd04e3e13</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831839</data>
  <data key="d6"></data>
</node>
