  <data key="d0">Cause And Effect Graphing</data>
  <data key="d1">method</data>
  <data key="d2">Cause and Effect Graphing is a black box testing method that analyzes the relationships between inputs and outputs.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831043</data>
  <data key="d6"></data>
</node>
<node id="Statement Testing">
  <data key="d0">Statement Testing</data>
  <data key="d1">method</data>
  <data key="d2">Statement Testing is a white box testing method that aims to execute every statement in the code at least once.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831044</data>
  <data key="d6"></data>
</node>
<node id="Branch Testing">
  <data key="d0">Branch Testing</data>
  <data key="d1">method</data>
  <data key="d2">Branch Testing is a white box testing method that aims to test all possible outcomes of each decision point in the code.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831044</data>
  <data key="d6"></data>
</node>
<node id="Path Testing">
  <data key="d0">Path Testing</data>
  <data key="d1">method</data>
  <data key="d2">Path Testing is a white box testing method that aims to test all possible execution paths in the code.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831045</data>
  <data key="d6"></data>
</node>
<node id="Data Flow Testing">
  <data key="d0">Data Flow Testing</data>
  <data key="d1">method</data>
  <data key="d2">Data Flow Testing is a white box testing method that examines the flow of data through the software.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831045</data>
  <data key="d6"></data>
</node>
<node id="Mutation Testing">
  <data key="d0">Mutation Testing</data>
  <data key="d1">method</data>
  <data key="d2">Mutation Testing is a white box testing method that introduces small changes to the code to test the effectiveness of test cases.</data>
  <data key="d3">chunk-4236e7b8427ccbaff16d4b0ef1506341</data>
  <data key="d4">unknown_source</data>
