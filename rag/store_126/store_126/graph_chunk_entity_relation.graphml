  <data key="d5">1770830612</data>
  <data key="d6"></data>
</node>
<node id="Testability">
  <data key="d0">Testability</data>
  <data key="d1">concept</data>
  <data key="d2">Testability indicates the degree of testing effort required.&lt;SEP&gt;Testability is the amount of effort needed to test software to ensure it performs according to specified requirements and reveals defects under testing conditions.</data>
  <data key="d3">chunk-c2d7d142472e7acf420224383c99b13b&lt;SEP&gt;chunk-7d1d7014ef279c74a7acb5889dca6440&lt;SEP&gt;chunk-ed0e4731c3296bc5ba3ae5edf4cd9631</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830775</data>
  <data key="d6"></data>
</node>
<node id="Correctability">
  <data key="d0">Correctability</data>
  <data key="d1">concept</data>
  <data key="d2">Correctability is the effort required to correct errors and handle user complaints.</data>
  <data key="d3">chunk-c2d7d142472e7acf420224383c99b13b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830614</data>
  <data key="d6"></data>
</node>
<node id="Walkthrough">
  <data key="d0">Walkthrough</data>
  <data key="d1">method</data>
  <data key="d2">A type of technical review where the producer of the material guides the review process.&lt;SEP&gt;Walkthrough is a type of formal technical review, more formal in nature and occur in a meeting-like setting.</data>
  <data key="d3">chunk-b7ff6ae81d2cbdd2fa63a7c1554d2eaf&lt;SEP&gt;chunk-c865455d56f087310ad4a2872dcee595</data>
