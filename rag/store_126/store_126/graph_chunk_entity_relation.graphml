  <data key="d1">data</data>
  <data key="d2">E2 represents one of the effects in the Decision Table.&lt;SEP&gt;E2 represents the position of character in string.</data>
  <data key="d3">chunk-ff3bcd5d811cf1d3238112df22f24549&lt;SEP&gt;chunk-dadd5fedffda581a4f86164ce8358084</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831827</data>
  <data key="d6"></data>
</node>
<node id="Debug Reports">
  <data key="d0">Debug Reports</data>
  <data key="d1">content</data>
  <data key="d2">Debug reports are generated for developers to debug failed test cases and the product.</data>
  <data key="d3">chunk-b6de8307f33f851b1e62ada0a1e5b961</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770830829</data>
  <data key="d6"></data>
</node>
<node id="Report Generator">
  <data key="d0">Report Generator</data>
  <data key="d1">method</data>
  <data key="d2">A module that takes necessary inputs and prepares a formatted report and can generate metrics.&lt;SEP&gt;The Report Generator prepares reports, which is part of the automation design.</data>
  <data key="d3">chunk-b6de8307f33f851b1e62ada0a1e5b961&lt;SEP&gt;chunk-f9a1e0b0e37c96741aefa49dc8030cdc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831790</data>
  <data key="d6"></data>
</node>
<node id="E3">
  <data key="d0">E3</data>
  <data key="d1">data</data>
  <data key="d2">E3 represents one of the effects in the Decision Table.&lt;SEP&gt;E3 represents the condition that the character is not found.</data>
  <data key="d3">chunk-ff3bcd5d811cf1d3238112df22f24549&lt;SEP&gt;chunk-dadd5fedffda581a4f86164ce8358084</data>
