<node id="Review Leader">
  <data key="d0">Review Leader</data>
  <data key="d1">person</data>
  <data key="d2">The review leader is responsible for review planning, preparing checklists, distributing review documents, managing the review meeting, issuing review reports, and follow-up oversight.</data>
  <data key="d3">chunk-71fc4f34702301e4dd6c1ae7beda783b</data>
