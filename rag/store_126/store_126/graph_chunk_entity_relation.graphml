  <data key="d0">Outstanding Defects Rate</data>
  <data key="d1">method</data>
  <data key="d2">Outstanding Defects Rate measures the proportion of unresolved defects.&lt;SEP&gt;The rate of defects that remain unresolved at a given time.</data>
