  <data key="d0">COTS(Commercial Off the Shelf) Software</data>
  <data key="d1">content</data>
  <data key="d2">COTS software is often tested using Alpha Testing to ensure internal acceptance before Beta Testing.</data>
  <data key="d3">chunk-9d01d5a91698d48273a7f4da4a262d5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770831192</data>
  <data key="d6"></data>
</node>
